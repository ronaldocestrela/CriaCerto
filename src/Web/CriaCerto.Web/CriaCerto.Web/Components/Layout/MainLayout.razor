@inherits LayoutComponentBase

<div class="shell-page">
    <aside class="shell-sidebar">
        <NavMenu />
    </aside>

    <main class="shell-main">
        <header class="shell-header">
            <div>
                <p class="shell-kicker">Cria Certo</p>
                <h1 class="shell-title">Swine Breeding Dashboard</h1>
            </div>
            <div class="shell-status">
                <span class="status-dot"></span>
                Offline-ready
            </div>
        </header>

        <article class="shell-content">
            @Body
        </article>
    </main>

    <nav class="mobile-tabs" aria-label="Mobile navigation">
        <NavLink href="" Match="NavLinkMatch.All">Dashboard</NavLink>
        <NavLink href="weather">Maternity</NavLink>
        <NavLink href="counter">Growth</NavLink>
    </nav>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
