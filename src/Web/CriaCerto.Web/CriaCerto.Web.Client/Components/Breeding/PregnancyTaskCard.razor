@using CriaCerto.Web.Client.Models

<article class="pregnancy-task-card @(Expanded ? "expanded" : "compact")">
    <div class="task-head">
        <div>
            <span class="task-label">Brinco ID</span>
            <strong class="task-tag">@Task.TagId</strong>
        </div>
        <div class="task-days">
            <span class="task-label">Pós-Cobertura</span>
            <div><strong>@Task.DaysPostBreeding</strong> Dias</div>
        </div>
    </div>

    @if (Expanded)
    {
        <div class="task-meta">
            <span><span class="material-symbols-outlined">person</span>Insem: <strong>@(Task.Technician ?? "—")</strong></span>
            <span><span class="material-symbols-outlined">location_on</span>Baia: <strong>@(Task.Location ?? "—")</strong></span>
        </div>
        <div class="task-actions-grid">
            <button type="button" class="action-pregnant" disabled="@Busy" @onclick="() => Submit(PregnancyDiagnosisResult.Pregnant)">
                <span class="material-symbols-outlined">check_circle</span>
                Prenhe (+)
            </button>
            <button type="button" class="action-empty" disabled="@Busy" @onclick="() => Submit(PregnancyDiagnosisResult.Empty)">
                <span class="material-symbols-outlined">cancel</span>
                Vazia (-)
            </button>
            <button type="button" class="action-return" disabled="@Busy" @onclick="() => Submit(PregnancyDiagnosisResult.ReturnToEstrus)">
                <span class="material-symbols-outlined">sync_problem</span>
                Retorno Cio
            </button>
            <button type="button" class="action-doubt" disabled="@Busy" @onclick="() => Submit(PregnancyDiagnosisResult.AbortOrDoubt)">
                <span class="material-symbols-outlined">help</span>
                Aborto/Dúvida
            </button>
        </div>
    }
    else
    {
        <div class="task-compact-meta">
            <span>Insem: <strong>@(Task.Technician ?? "—")</strong></span>
            <button type="button" class="task-expand" @onclick="OnExpand">Ver detalhes</button>
        </div>
        <div class="task-actions-row">
            <button type="button" class="mini-pregnant" disabled="@Busy" @onclick="() => Submit(PregnancyDiagnosisResult.Pregnant)"><span class="material-symbols-outlined">add</span></button>
            <button type="button" class="mini-empty" disabled="@Busy" @onclick="() => Submit(PregnancyDiagnosisResult.Empty)"><span class="material-symbols-outlined">remove</span></button>
            <button type="button" class="mini-return" disabled="@Busy" @onclick="() => Submit(PregnancyDiagnosisResult.ReturnToEstrus)"><span class="material-symbols-outlined">replay</span></button>
            <button type="button" class="mini-doubt" disabled="@Busy" @onclick="() => Submit(PregnancyDiagnosisResult.AbortOrDoubt)"><span class="material-symbols-outlined">question_mark</span></button>
        </div>
    }
</article>

@code {
    [Parameter, EditorRequired]
    public PregnancyCheckTaskDto Task { get; set; } = default!;

    [Parameter]
    public bool Expanded { get; set; }

    [Parameter]
    public bool Busy { get; set; }

    [Parameter]
    public EventCallback<PregnancyDiagnosisResult> OnDiagnose { get; set; }

    [Parameter]
    public EventCallback OnExpand { get; set; }

    private Task Submit(PregnancyDiagnosisResult result) => OnDiagnose.InvokeAsync(result);
}
