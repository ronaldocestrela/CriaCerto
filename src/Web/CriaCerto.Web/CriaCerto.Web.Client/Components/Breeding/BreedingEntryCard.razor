@using CriaCerto.Web.Client.Models

<article class="breeding-entry-card @(IsActive ? "active-card" : "draft-card")">
    @if (IsActive)
    {
        <div class="entry-accent"></div>
    }
    <div class="entry-grid">
        <div class="entry-field span-2">
            <label>BRINCO DA MATRIZ</label>
            <div class="entry-tag-input">
                <input @bind="Entry.TagId" @bind:event="oninput" placeholder="000-000" class="tag-input" />
                <button type="button" class="scan-btn" aria-label="Escanear brinco">
                    <span class="material-symbols-outlined">barcode_scanner</span>
                </button>
            </div>
        </div>
        <div class="entry-field">
            <label>TIPO</label>
            <select @bind="Entry.Method">
                <option value="@BreedingMethod.ArtificialInsemination">IA</option>
                <option value="@BreedingMethod.TimedArtificialInsemination">IATF</option>
                <option value="@BreedingMethod.NaturalService">Monta Natural</option>
            </select>
        </div>
        <div class="entry-field">
            <label>CACHAXO/SÊMEN</label>
            <input @bind="Entry.BoarOrSemenRef" placeholder="ID Lote" />
        </div>
        <div class="entry-field">
            <label>TÉCNICO</label>
            <select @bind="Entry.Technician">
                <option>Ricardo S.</option>
                <option>Marcos V.</option>
                <option>Elena G.</option>
            </select>
        </div>
        <div class="entry-field">
            <label>ECC (1-5)</label>
            <EccStepper @bind-Value="Entry.EccScore" />
        </div>
    </div>
    @if (ShowRemove)
    {
        <button type="button" class="remove-entry-btn" @onclick="OnRemove">Remover</button>
    }
</article>

@code {
    [Parameter, EditorRequired]
    public BreedingEntryFormModel Entry { get; set; } = default!;

    [Parameter]
    public bool IsActive { get; set; }

    [Parameter]
    public bool ShowRemove { get; set; }

    [Parameter]
    public EventCallback OnRemove { get; set; }
}
