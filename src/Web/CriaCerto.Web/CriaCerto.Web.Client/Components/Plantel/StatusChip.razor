@using CriaCerto.Web.Client.Models

<span class="plantel-chip @CssClass">
    @Label
</span>

@code {
    [Parameter]
    public ReproductiveStatus? ReproductiveStatus { get; set; }

    [Parameter]
    public LifecycleStatus? LifecycleStatus { get; set; }

    [Parameter]
    public bool Attention { get; set; }

    private string Label
    {
        get
        {
            if (Attention)
            {
                return "ATENÇÃO";
            }

            if (LifecycleStatus == CriaCerto.Web.Client.Models.LifecycleStatus.Quarantine)
            {
                return "QUARENTENA";
            }

            if (LifecycleStatus == CriaCerto.Web.Client.Models.LifecycleStatus.Culled)
            {
                return "DESCARTADO";
            }

            return ReproductiveStatus switch
            {
                CriaCerto.Web.Client.Models.ReproductiveStatus.Empty => "VAZIA",
                CriaCerto.Web.Client.Models.ReproductiveStatus.Bred => "COBERTA",
                CriaCerto.Web.Client.Models.ReproductiveStatus.Pregnant => "GESTANTE",
                CriaCerto.Web.Client.Models.ReproductiveStatus.Lactating => "LACTANTE",
                _ => "ATIVO"
            };
        }
    }

    private string CssClass
    {
        get
        {
            if (Attention)
            {
                return "chip-alert";
            }

            if (LifecycleStatus == CriaCerto.Web.Client.Models.LifecycleStatus.Quarantine)
            {
                return "chip-warning";
            }

            if (LifecycleStatus == CriaCerto.Web.Client.Models.LifecycleStatus.Culled)
            {
                return "chip-muted";
            }

            return ReproductiveStatus switch
            {
                CriaCerto.Web.Client.Models.ReproductiveStatus.Empty => "chip-empty",
                CriaCerto.Web.Client.Models.ReproductiveStatus.Bred => "chip-bred",
                CriaCerto.Web.Client.Models.ReproductiveStatus.Pregnant => "chip-pregnant",
                CriaCerto.Web.Client.Models.ReproductiveStatus.Lactating => "chip-lactating",
                _ => "chip-active"
            };
        }
    }
}
