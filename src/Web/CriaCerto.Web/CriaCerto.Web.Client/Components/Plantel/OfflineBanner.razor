@if (Visible)
{
    <div class="plantel-offline-banner" role="status">
        <span class="material-symbols-outlined">signal_wifi_off</span>
        <span>@Message</span>
    </div>
}

@code {
    [Parameter]
    public bool Visible { get; set; }

    [Parameter]
    public string Message { get; set; } = "Modo Offline - Sincronização pendente";
}
